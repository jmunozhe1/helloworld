pipeline {
    agent none

    stages {
        stage('Install Python') {
            agent any
            steps {
                bat '''
                    REM Descargar Python portable (embedded)
                    cd %WORKSPACE%
                    curl -o python-embed.zip https://www.python.org/ftp/python/3.12.3/python-3.12.3-embed-amd64.zip
                    tar -xf python-embed.zip -C python
                    del python-embed.zip
                    
                    REM Descargar get-pip.py
                    curl -o get-pip.py https://bootstrap.pypa.io/get-pip.py
                    
                    REM Instalar pip
                    .\\python\\python.exe get-pip.py --no-warn-script-location
                    del get-pip.py
                    
                    REM Instalar pytest y flask
                    .\\python\\python.exe -m pip install pytest flask --no-warn-script-location
                    
                    REM Crear archivo de configuración para evitar conflictos de PATH
                    echo .\\python\\python310._pth > python\\python310._pth
                '''
            }
        }
        stage('Build') {
            agent any
            steps {
                echo 'Build stage...'
                bat 'dir'
            }
        }

        stage('Tests') {
            parallel {
                stage('Unit') {
                    agent any
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            bat '''
                                set PATH=%USERPROFILE%\\AppData\\Roaming\\Python\\Python312\\Scripts;%PATH%
                                set PYTHONPATH=%WORKSPACE%
                                python -m pytest --junitxml=result-unit.xml test\\unit
                            '''
                        }
                    }
                }
                
                stage('Rest') {
                    agent any
                    steps {
                        bat '''
                            set PATH=%USERPROFILE%\\AppData\\Roaming\\Python\\Python312\\Scripts;%PATH%
                            set FLASK_APP=app\\api.py
                            set FLASK_ENV=development
                            set PYTHONPATH=%WORKSPACE%
                            python -m pytest --junitxml=result-rest.xml test\\rest
                        '''
                    }    
                }    
            }
        }
        
        stage('Results') {
            agent any
            steps {
                junit 'result*.xml'
            }
        }
    }
}