pipeline {
    agent none

    stages {
        // stage('Setup') {
        //     agent any
        //     steps {
        //         bat '''
        //             python -m pip install --user pytest
        //             set PATH=%USERPROFILE%\\AppData\\Roaming\\Python\\Python312\\Scripts;%PATH%
        //         '''
        //     }
        // }
        stage('Check PATH') {
            agent any
            steps {
                bat 'echo %PATH%'
                bat 'where python'
            }
        }
        stage('Build') {
            agent any
            steps {
                echo 'Build stage...'
                bat 'dir'
            }
        }

        stage('Tests') {
            parallel {
                stage('Unit') {
                    agent any
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            bat '''
                                set PATH=%USERPROFILE%\\AppData\\Roaming\\Python\\Python312\\Scripts;%PATH%
                                set PYTHONPATH=%WORKSPACE%
                                python -m pytest --junitxml=result-unit.xml test\\unit
                            '''
                        }
                    }
                }
                
                stage('Rest') {
                    agent any
                    steps {
                        bat '''
                            set PATH=%USERPROFILE%\\AppData\\Roaming\\Python\\Python312\\Scripts;%PATH%
                            set FLASK_APP=app\\api.py
                            set FLASK_ENV=development
                            set PYTHONPATH=%WORKSPACE%
                            python -m pytest --junitxml=result-rest.xml test\\rest
                        '''
                    }    
                }    
            }
        }
        
        stage('Results') {
            agent any
            steps {
                junit 'result*.xml'
            }
        }
    }
}