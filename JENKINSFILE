pipeline {
    agent none

    stages {
        stage('Build') {
            agent any
            steps {
                echo 'Build stage...'
                echo WORKSPACE
                bat 'dir'
            }
        }

        stage('Tests') {
            parallel {
                stage('Unit') {
                    agent any
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            bat '''
                                set PATH=%USERPROFILE%\\AppData\\Roaming\\Python\\Python312\\Scripts;%PATH%
                                set PYTHONPATH=%WORKSPACE%
                                python -m pytest --junitxml=result-unit.xml test\\unit
                            '''
                        }
                    }
                }
                
                stage('Rest') {
                    agent any
                    steps {
                        bat '''
                            @echo off
                            set PATH=C:\\Python312;C:\\Python312\\Scripts;%PATH%
                            set PYTHONPATH=%WORKSPACE%
                            set FLASK_APP=app\\api.py
                            
                            echo [1/4] Descargando WireMock standalone...
                            :: Descarga el JAR oficial directamente al espacio de trabajo de Jenkins
                            powershell -Command "Invoke-WebRequest -Uri 'https://repo1.maven.org/maven2/com/github/tomakehurst/wiremock-jre8-standalone/2.28.0/wiremock-jre8-standalone-2.28.0.jar' -OutFile 'wiremock-standalone.jar'"
                            
                            echo [2/4] Levantando Flask en puerto 5000...
                            start /B python -m flask run --port 5000
                            
                            echo [3/4] Levantando WireMock en puerto 9090...
                            start /B java -jar wiremock-standalone.jar --port 9090 --root-dir "%WORKSPACE%\\test\\wiremock"
                            
                            echo [4/4] Esperando a que los servicios respondan...
                            ping -n 11 127.0.0.1 > nul
                            
                            echo Ejecutando pruebas con Pytest...
                            python -m pytest --junitxml=result-rest.xml test\\rest
                        '''
                    }    
                }    
            }
        }
        
        stage('Results') {
            agent any
            steps {
                junit 'result*.xml'
            }
        }
    }
}