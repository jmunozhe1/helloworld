pipeline {
    agent none

    stages {
        stage('Build') {
            agent any
            steps {
                echo 'Build stage...'
                echo WORKSPACE
                bat 'dir'
            }
        }

        stage('Tests') {
            parallel {
                stage('Unit') {
                    agent any
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            bat '''
                                set PATH=%USERPROFILE%\\AppData\\Roaming\\Python\\Python312\\Scripts;%PATH%
                                set PYTHONPATH=%WORKSPACE%
                                python -m pytest --junitxml=result-unit.xml test\\unit
                            '''
                        }
                    }
                }
                
                stage('Rest') {
                    agent any
                    steps {
                        bat '''
                        set PATH=C:\\Python312;C:\\Python312\\Scripts;%PATH%
                        set PYTHONPATH=%WORKSPACE%
                        set FLASK_APP=app\\api.py
                        
                        :: 1. Lanzar la API principal (Puerto 5000)
                        start /B python -m flask run --port 5000
                        
                        :: 2. Lanzar el MOCK (Puerto 9090) 
                        :: Ajusta el comando si el mock se lanza con otro script, por ejemplo:
                        start /B python app\\mock_service.py 
                        
                        :: 3. Esperar 5 segundos (usando ping en lugar de timeout)
                        ping -n 6 127.0.0.1 > nul
                        
                        :: 4. Ejecutar los tests
                        python -m pytest --junitxml=result-rest.xml test\\rest
                    '''
                    }    
                }    
            }
        }
        
        stage('Results') {
            agent any
            steps {
                junit 'result*.xml'
            }
        }
    }
}